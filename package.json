{
  "name": "landing-page",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "lint:fix": "eslint . --fix --cache --cache-location .eslintcache",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,mjs,json,css,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,mjs,json,css,md,yml,yaml}\"",
    "knip": "knip",
    "knip:production": "knip --production",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:video-to-gif": "playwright test tests/studio.spec.ts tests/video-to-gif-accessibility.spec.ts tests/video-to-gif-seo.spec.ts",
    "test:ui": "playwright test --ui",
    "validate": "npm run lint && npm run format:check && npm run typecheck && npm run knip:production && npm run test:unit && npm run build && npm run test:e2e",
    "verify:public-tool": "node scripts/verify-public-tool.mjs",
    "verify:ci-boundaries": "node scripts/verify-ci-boundaries.mjs",
    "pre-push": "bash scripts/pre-push.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.10",
    "gifenc": "^1.0.3",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.552.0",
    "next": "^16.2.10",
    "postcss": "8.5.17",
    "posthog-js": "^1.399.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "knip": "^6.24.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "puppeteer": "^24.28.0",
    "serve": "^14.2.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "postcss": "8.5.17"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": "prettier --write"
  }
}
