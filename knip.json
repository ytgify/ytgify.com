{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["app/**/*.{ts,tsx}", "lib/**/*.ts"],
  "project": ["**/*.{ts,tsx,js,mjs}"],
  "ignore": [
    "content/**/*",
    "docs/goals/**/.goalbuddy-board/**/*",
    "scripts/**/*"
  ],
  "ignoreDependencies": [
    "puppeteer",
    "remark-frontmatter",
    "remark-gfm",
    "remark-mdx-frontmatter"
  ]
}
